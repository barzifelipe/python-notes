   "source": [
    "import matplotlib.pyplot as plt\n",
    "\n",
    "categorias = [\"Python\", \"SQL\", \"Power BI\"]\n",
    "horas = [10, 5, 3]\n",
    "\n",
    "plt.pie(horas, labels=categorias)\n",
    "\n",
    "plt.title(\"Horas de Estudo\")\n",
    "\n",
    "plt.show()"
   ]
